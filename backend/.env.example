DATABASE_URL=postgresql+psycopg2://hmeayc:hmeayc@localhost:5432/hmeayc
GEMINI_API_KEY=your_gemini_api_key_here
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Local dev only — production MUST override this (see deploy/README.md).
JWT_SECRET=

# Org-invite emails (POST /api/orgs/{orgId}/invite) are sent through this SMTP relay.
# Leave SMTP_HOST empty to just log the email body instead of sending it (fine for local dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hmeayc.local
# Base URL used to build the invite-accept link (POST /dashboard/accept-invite?token=...).
APP_BASE_URL=http://localhost:5173

# ESP32 firmware API key (X-API-Key header). Leave empty to disable API-key auth.
HMEAYC_API_KEY=

# Video analysis task TTL in seconds (default 86400 = 24h).
HMEAYC_TASK_TTL_SEC=86400

# AI report augmentation (optional, for POST /api/analyze).
KINDER_AI_API_KEY=
OPENAI_API_KEY=
KINDER_AI_BASE_URL=https://api.openai.com/v1
KINDER_AI_MODEL=gpt-4o-mini
