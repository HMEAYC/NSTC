menu "HMEAYC Firmware Configuration"

    config HMEAYC_DEVICE_ID
        string "Device ID"
        default "hmeayc-001"
        help
            Unique identifier for this device, sent in every IMU frame.

    config HMEAYC_FIRMWARE_VERSION
        string "Firmware Version"
        default "1.0.0"
        help
            Semver version string reported to OTA server.

    config HMEAYC_WIFI_SSID
        string "WiFi SSID"
        default "HMEAYC"

    config HMEAYC_WIFI_PASSWORD
        string "WiFi Password"
        default ""

    config HMEAYC_WS_URI
        string "WebSocket URI"
        default "ws://192.168.0.129:8080/ws/default"
        help
            Base WebSocket URI. The session path is dynamically updated at runtime
            via GET /api/config/session — the ESP32 will reconnect to the correct
            session when assigned via the dashboard. If no session is assigned,
            falls back to "/ws/default".

    config HMEAYC_SAMPLE_RATE_HZ
        int "IMU Sample Rate (Hz)"
        default 50
        range 5 200
        help
            IMU sampling frequency. MPU6050/MPU6500 supports 5-200 Hz with DLPF enabled.

    config HMEAYC_API_BASE_URL
        string "API Server Base URL"
        default "http://192.168.0.129:8080/api"
        help
            Base URL for REST API calls (device registration, WiFi config fetch).
            Must NOT have a trailing slash.

    config HMEAYC_OTA_BASE_URL
        string "OTA Server Base URL"
        default "http://192.168.0.129:8080/api/firmware"
        help
            Base URL for OTA version check and firmware download.
            Must NOT have a trailing slash.

endmenu
